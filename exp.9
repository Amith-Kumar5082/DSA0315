import nltk

patterns = [
    (r'.*ing$', 'VBG'),
    (r'.*ed$', 'VBD'),
    (r'.*es$', 'VBZ'),
    (r'.*ould$', 'MD'),
    (r'.*\'s$', 'NN$'),
    (r'.*s$', 'NNS'),
    (r'^-?[0-9]+$', 'CD'),
    (r'.*', 'NN')
]

tagger = nltk.RegexpTagger(patterns)

sentence = "Dogs are running in the garden".split()

print(tagger.tag(sentence))
